{
  "name": "foretrace-vscode",
  "displayName": "Foretrace",
  "description": "Stream integrated-terminal output to Foretrace (batched POST …/terminal/batches). MVP VSIX.",
  "version": "0.1.11",
  "publisher": "foretrace",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/TamehChana/foretrace.git",
    "directory": "extensions/foretrace-vscode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "enabledApiProposals": ["terminalDataWriteEvent"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:foretrace.setCliToken",
    "onCommand:foretrace.sendTestBatch",
    "onCommand:foretrace.sendEditorSelection",
    "onCommand:foretrace.startTerminalCapture",
    "onCommand:foretrace.stopTerminalCapture",
    "onCommand:foretrace.openCaptureTerminal",
    "onCommand:foretrace.showLog"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "foretrace.setCliToken",
        "title": "Foretrace: Set CLI ingest token"
      },
      {
        "command": "foretrace.sendTestBatch",
        "title": "Foretrace: Send test batch (one line)"
      },
      {
        "command": "foretrace.sendEditorSelection",
        "title": "Foretrace: Send editor selection (or visible range if empty)"
      },
      {
        "command": "foretrace.startTerminalCapture",
        "title": "Foretrace: Start terminal capture"
      },
      {
        "command": "foretrace.stopTerminalCapture",
        "title": "Foretrace: Stop terminal capture"
      },
      {
        "command": "foretrace.openCaptureTerminal",
        "title": "Foretrace: Open capture terminal (Cursor-safe)"
      },
      {
        "command": "foretrace.showLog",
        "title": "Foretrace: Open output log"
      }
    ],
    "configuration": {
      "title": "Foretrace",
      "properties": {
        "foretrace.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Foretrace API base URL (no trailing slash), e.g. https://your-api.onrender.com"
        },
        "foretrace.organizationId": {
          "type": "string",
          "default": "",
          "description": "Organization UUID"
        },
        "foretrace.projectId": {
          "type": "string",
          "default": "",
          "description": "Project UUID (must match the project where the CLI token was minted)"
        },
        "foretrace.cliToken": {
          "type": "string",
          "default": "",
          "description": "Optional CLI ingest token (ft_ck_…). Prefer “Foretrace: Set CLI ingest token” (secret storage). Settings fallback for local setup."
        },
        "foretrace.flushIntervalMs": {
          "type": "number",
          "default": 180000,
          "minimum": 500,
          "maximum": 300000,
          "description": "How often to POST batched terminal lines while capture is running (default 3 min / 180000 ms; max 5 min / 300000 ms)"
        },
        "foretrace.autoStartTerminalCapture": {
          "type": "boolean",
          "default": false,
          "description": "When true, start terminal capture on activate if apiBaseUrl, organizationId, projectId, and a stored CLI token are already set"
        },
        "foretrace.captureLogPath": {
          "type": "string",
          "default": "",
          "description": "Optional path for file-based capture (default ~/.foretrace/capture.log). Used in Cursor when live terminal streaming is blocked."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "1.74.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "~5.7.3"
  }
}
