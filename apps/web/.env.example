# =============================================================================
# Copy to `apps/web/.env` for local dev (gitignored).
# =============================================================================
#
# If unset: Vite proxies /health, /auth/*, /organizations to localhost:3000.
#
# Recommended (API on Render, SPA on Vercel): point at your Render Nest URL:
# VITE_API_URL=https://YOUR-SERVICE.onrender.com
#
# Local API instead:
# VITE_API_URL=http://localhost:3000
