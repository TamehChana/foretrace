generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PM
  DEVELOPER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TerminalIncidentCategory {
  BUILD
  TEST
  RUNTIME
  DEPENDENCY
  DB
  API
  DOCKER
  UNKNOWN
}

/// Project-level delivery risk (SRS §8 v0 — rule fusion on signal snapshot).
enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertKind {
  RISK_EVALUATION
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships      Membership[]
  tasksCreated     Task[]           @relation("TaskCreator")
  tasksOwned       Task[]           @relation("TaskAssignee")
  githubUserLinks  GitHubUserLink[]
  cliIngestTokens CliIngestToken[]
  auditLogs       AuditLog[]
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships              Membership[]
  projects                 Project[]
  cliIngestTokens         CliIngestToken[]
  terminalIngestBatches   TerminalIngestBatch[]
  terminalIncidents        TerminalIncident[]
  projectSignalSnapshots   ProjectSignalSnapshot[]
  projectRiskEvaluations   ProjectRiskEvaluation[]
  riskEvaluationRuns       RiskEvaluationRun[]
  alerts                   Alert[]
  auditLogs                AuditLog[]
}

model Membership {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  organizationId String   @db.Uuid
  role           Role     @default(DEVELOPER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  description    String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks                Task[]
  githubConnection     GitHubConnection?
  cliIngestTokens      CliIngestToken[]
  terminalIngestBatches TerminalIngestBatch[]
  terminalIncidents    TerminalIncident[]
  signalSnapshot       ProjectSignalSnapshot?
  riskEvaluation       ProjectRiskEvaluation?
  riskEvaluationRuns   RiskEvaluationRun[]
  alerts               Alert[]

  @@index([organizationId])
}

/// Links a GitHub repository to a project (one connection per project in v1).
model GitHubConnection {
  id                   String    @id @default(uuid()) @db.Uuid
  projectId            String    @unique @db.Uuid
  /// Normalized lowercase `owner/name` — matched against webhook payload.repository.full_name
  repositoryFullName   String
  webhookSecret        String
  lastEventAt          DateTime?
  lastPushAt           DateTime?
  openPullRequestCount Int       @default(0)
  openIssueCount       Int       @default(0)
  /// AES-256-GCM ciphertext (base64) for optional GitHub REST enrichment; requires `FORETRACE_APP_SECRET` on API.
  githubPatCiphertext  String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  project    Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events     GitHubWebhookEvent[]
  userLinks  GitHubUserLink[]

  @@unique([repositoryFullName])
}

/// Idempotent store of webhook deliveries (GitHub may retry identical payloads).
model GitHubWebhookEvent {
  id               String   @id @default(uuid()) @db.Uuid
  connectionId     String   @db.Uuid
  githubDeliveryId String   @unique
  eventType        String
  action           String?
  actorLogin       String?
  payload          Json
  createdAt        DateTime @default(now())

  connection GitHubConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt(sort: Desc)])
}

/// Maps a GitHub login to an app User within a repo connection’s project context.
model GitHubUserLink {
  id           String   @id @default(uuid()) @db.Uuid
  connectionId String   @db.Uuid
  githubLogin  String
  userId       String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection GitHubConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([connectionId, githubLogin])
  @@index([userId])
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @db.Uuid
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime?
  status      TaskStatus   @default(TODO)
  progress    Int          @default(0)
  assigneeId  String?      @db.Uuid
  createdById String       @db.Uuid
  /// When set, matches `repository` issue number for this project’s linked GitHub repo.
  githubIssueNumber      Int?
  lastGithubActivityAt   DateTime?
  lastGithubActorLogin   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project               Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee              User?                @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy              User                 @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  terminalIngestBatches  TerminalIngestBatch[]
  terminalIncidents      TerminalIncident[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([deadline])
  @@index([projectId, githubIssueNumber])
}

/// Project-scoped secret for the Foretrace CLI (`Authorization: Bearer ft_ck_...`). Only a SHA-256 digest is stored.
model CliIngestToken {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  projectId      String    @db.Uuid
  /// Only the digest of the raw bearer token is persisted.
  secretDigest   String    @unique
  name           String?
  createdById    String    @db.Uuid
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  batches TerminalIngestBatch[]

  @@index([projectId])
  @@index([organizationId])
}

/// One POST from the CLI (or other client) carrying many log lines.
model TerminalIngestBatch {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  projectId      String   @db.Uuid
  cliTokenId     String   @db.Uuid
  taskId         String?  @db.Uuid
  lineCount      Int
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  token        CliIngestToken @relation(fields: [cliTokenId], references: [id], onDelete: Cascade)
  task         Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)

  incidents TerminalIncident[]

  @@index([projectId, createdAt(sort: Desc)])
}

/// Coarse terminal signal (build/test noise) with fingerprint dedupe per project.
model TerminalIncident {
  id               String                   @id @default(uuid()) @db.Uuid
  organizationId   String                   @db.Uuid
  projectId        String                   @db.Uuid
  taskId           String?                  @db.Uuid
  batchId          String?                  @db.Uuid
  category         TerminalIncidentCategory
  fingerprint      String
  /// Redacted excerpt (truncated)
  excerpt          String                   @db.Text
  firstSeenAt      DateTime                 @default(now())
  lastSeenAt       DateTime                 @updatedAt
  occurrenceCount  Int                      @default(1)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task         Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  batch        TerminalIngestBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@unique([projectId, fingerprint])
  @@index([projectId, lastSeenAt(sort: Desc)])
}

/// Rolled-up signals for dashboard / future risk engine (SRS §7 slice).
model ProjectSignalSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  projectId      String   @unique @db.Uuid
  /// Rolling window length used for this snapshot (hours).
  windowHours    Int      @default(24)
  /// Structured metrics (GitHub, terminal, tasks).
  payload        Json
  computedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([computedAt(sort: Desc)])
}

/// Latest persisted project risk (v0: one row per project, recomputed on demand).
model ProjectRiskEvaluation {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  projectId      String    @unique @db.Uuid
  level          RiskLevel
  score          Int
  /// Machine-readable reasons: `[{ "code": "TASKS_OVERDUE", "detail": "…" }]`
  reasons        Json
  /// Optional human-facing narrative (heuristic and/or LLM). See `docs/AI.md`.
  aiSummary      String?   @db.Text
  evaluatedAt    DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([evaluatedAt(sort: Desc)])
}

/// Append-only risk evaluation history (production trend / audit trail).
model RiskEvaluationRun {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  projectId      String    @db.Uuid
  level          RiskLevel
  score          Int
  reasons        Json
  aiSummary      String?   @db.Text
  evaluatedAt    DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, evaluatedAt(sort: Desc)])
  @@index([organizationId, evaluatedAt(sort: Desc)])
}

/// In-app notification (v0: risk elevation / worsening).
model Alert {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  projectId      String    @db.Uuid
  kind           AlertKind @default(RISK_EVALUATION)
  summary        String    @db.VarChar(500)
  payload        Json?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, readAt, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
}

/// Immutable audit trail for security-sensitive actions (enterprise baseline).
model AuditLog {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  actorUserId      String?  @db.Uuid
  action           String
  resourceType     String?
  resourceId       String?  @db.Uuid
  metadata         Json?
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
}
