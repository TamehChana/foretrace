# Copy to `.env` at the **repository root** and to **`apps/api/.env`** (same values).
# Both are gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# Database (pick one)
# ---------------------------------------------------------------------------

# --- Render PostgreSQL (recommended if you’re not running Postgres locally) ---
# In Render: open your **PostgreSQL** instance → **Connections**.
# Copy the **External Database URL** (use that from your laptop / home network).
# It is a full `postgresql://...` string (often includes SSL). Paste as a single line.
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# --- Local PostgreSQL ---
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE

# ---------------------------------------------------------------------------
# App (local dev optional; required on Render in production)
# ---------------------------------------------------------------------------

# SESSION_SECRET=replace-with-a-long-random-secret

# API CORS (Render): comma-separated origins for your deployed web app.
# CORS_ORIGINS=https://your-app.vercel.app

# Public API base URL (optional). Used in GitHub connection responses for webhook URL hints.
# Example: https://foretrace-api.onrender.com
# API_PUBLIC_URL=
