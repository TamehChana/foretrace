# Copy to `.env` at repo root or `apps/api/.env`.
# Postgres 16. Default matches docker-compose.yml; same user/database on a local install if you skip Docker.
DATABASE_URL=postgresql://foretrace:foretrace@localhost:5432/foretrace

# Required in production (NODE_ENV=production). Development falls back to a dev-only default if unset.
# Use a long random string (32+ characters).
# SESSION_SECRET=replace-with-a-long-random-secret

# Render production (optional locally): comma-separated origins allowed to call the API from the browser (your Vercel URL(s)).
# CORS_ORIGINS=https://your-app.vercel.app
