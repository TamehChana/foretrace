# =============================================================================
# Copy this file to `.env` (repo root) AND `apps/api/.env` — same keys/values.
# Never commit real `.env` files.
# =============================================================================
#
# Recommended split (see README “Deployment”):
#   • Nest API on Render → public URL like https://YOUR-SERVICE.onrender.com
#   • Vite SPA on Vercel → CORS_ORIGINS lists that SPA origin (not the API host).
#   • apps/web/.env → VITE_API_URL = same Render API URL (baked in at Vercel build).
#   • Optional: FORETRACE_* and smoke script target the same Render API URL.
#
# =============================================================================
# REQUIRED for the API (local + production)
# =============================================================================

# Postgres connection string (one line). From Render Postgres → Connections → External URL,
# or Neon, or local Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Random string, 32+ characters. Used to sign session cookies and SPA bearer tokens
# (`accessToken` from POST /auth/login and /auth/register).
SESSION_SECRET="replace-with-a-long-random-secret-min-32-chars"

# When NODE_ENV=production: add Partitioned (CHIPS) on the session cookie so Chrome is more
# likely to send it on credentialed fetches from a different site (e.g. Vercel → Render).
# Set to 0/false/off/no to omit Partitioned if a client misbehaves.
# SESSION_COOKIE_PARTITIONED=1

# Min 16 characters. Encrypts optional per-project GitHub PATs at rest (AES-256-GCM).
# If unset or too short, PAT save is rejected and REST enrichment is skipped.
FORETRACE_APP_SECRET="replace-with-a-long-random-secret-min-16-chars"

# Browser origins allowed to call the API with cookies (comma-separated, NO trailing slash).
# Put your FRONTEND URL(s) here — the site users open in the browser — NOT the API host
# unless the UI is served from the API domain.
# Example (Vercel web app): https://my-foretrace.vercel.app
# Example (multiple): https://app.vercel.app,https://app.example.com
CORS_ORIGINS="https://YOUR-FRONTEND.vercel.app"

# =============================================================================
# REQUIRED in production (cookies + CORS + webhook hints)
# =============================================================================

# For local `npm install` / `tsc`, use `development` so workspace devDependencies
# (e.g. @types/*) are installed. Use `production` only on the deployed API host.
NODE_ENV="development"

# Public HTTPS base URL of THIS API (no trailing slash) — use your Render service URL.
API_PUBLIC_URL="https://YOUR-SERVICE.onrender.com"

# Optional: shown in GET /health as `version` (e.g. git SHA from CI).
# FORETRACE_BUILD_ID="abc1234"

# =============================================================================
# OPTIONAL — Email (risk alerts → org ADMIN + PM inboxes)
# =============================================================================
# Set MAIL_ENABLED=1 and configure SMTP to send when in-app risk alerts are created.
# MAIL_ENABLED="1"
# MAIL_FROM="Foretrace <noreply@yourdomain.com>"
# Either a single URL:
# SMTP_URL="smtps://user:pass@smtp.example.com:465"
# Or discrete host auth (port defaults 587; set SMTP_SECURE=1 for implicit TLS):
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="apikey-or-user"
# SMTP_PASS="secret"
# SMTP_SECURE="0"

# =============================================================================
# OPTIONAL — OpenAI narrative on risk “Evaluate” (see docs/AI.md)
# =============================================================================
# OPENAI_API_KEY="sk-…"
# OPENAI_RISK_MODEL="gpt-4o-mini"
# Optional: separate model id for POST …/insights/analyze (defaults to OPENAI_RISK_MODEL)
# OPENAI_IMPACT_MODEL="gpt-4o-mini"

# =============================================================================
# OPTIONAL — Risk ML (multinomial level + deadline pressure index; see docs/ML-RISK.md)
# =============================================================================
# FORETRACE_ML_RISK_ENABLED=1
# FORETRACE_ML_RISK_WEIGHTS_PATH="apps/api/src/ml/risk-ml-v1.weights.json"

# =============================================================================
# OPTIONAL — Scheduled snapshot refresh (HTTP cron; see .github/workflows/foretrace-snapshots-cron.example.yml)
# =============================================================================
# Shared secret: send header `X-Foretrace-Cron-Secret` on POST /internal/cron/refresh-project-snapshots
# FORETRACE_CRON_SECRET="long-random-string"

# =============================================================================
# OPTIONAL — Vercel preview CORS (wide; avoid for strict production)
# =============================================================================
# CORS_ALLOW_VERCEL_PREVIEW=1

# =============================================================================
# OPTIONAL — Foretrace CLI (`foretrace ingest` / `npm run terminal:ingest`)
# =============================================================================
# Same host as the API you want to send logs to (no trailing slash).
# FORETRACE_API_URL="https://YOUR-SERVICE.onrender.com"
# FORETRACE_TOKEN="ft_ck_…"
# FORETRACE_ORGANIZATION_ID="00000000-0000-4000-8000-000000000000"
# FORETRACE_PROJECT_ID="00000000-0000-4000-8000-000000000000"
# FORETRACE_TASK_ID=""
# foretrace run only: "always" (default) = ingest whenever there is output (green or red builds).
# Set to "failure" to ingest only when the wrapped command exits ≠ 0.
# FORETRACE_INGEST_ON=failure

# =============================================================================
# OPTIONAL — Smoke script (`npm run smoke:terminal-ingest`)
# =============================================================================
# FORETRACE_EMAIL="you@example.com"
# FORETRACE_PASSWORD="your-app-password"
# Or paste session cookie from browser (Application → Cookies → API host):
# FORETRACE_COOKIE="foretrace.sid=s%3A..."
