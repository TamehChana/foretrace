{
  "name": "foretrace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "sync-web-dist-root": "node scripts/sync-web-dist-root.mjs",
    "build:vercel": "npm run build -w @foretrace/shared && npm run build -w @foretrace/web && npm run sync-web-dist-root",
    "vercel-build": "npm ci --include=dev && npm install vite@8.0.11 --no-save --workspace=@foretrace/web"
  },
  "dependencies": {
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  }
}
