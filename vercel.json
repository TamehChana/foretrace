{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && npm install vite@8.0.11 --no-save --workspace=@foretrace/web",
  "buildCommand": "cd \"$(git rev-parse --show-toplevel)\" && npx --yes turbo@2.9.12 run build --filter=@foretrace/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
