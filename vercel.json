{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci --include=dev && npm install vite@8.0.11 --no-save --workspace=@foretrace/web",
  "buildCommand": "npm run build -w @foretrace/shared && npm run build -w @foretrace/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
